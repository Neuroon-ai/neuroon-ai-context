llm:
  # Opciones comunes: anthropic, openai, openrouter, google
  provider: anthropic
  # Modelos recomendados para coding: claude-3-5-sonnet-20240620, gpt-4o
  model: claude-3-5-sonnet-20240620

gateway:
  # Habilitamos el modo headless para workers
  enabled: true
  
tools:
  # Permitimos que use bash y edite archivos
  bash: true
  filesystem: true
  github: true
